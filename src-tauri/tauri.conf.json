{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Foliate for Windows",
  "version": "0.1.4",
  "identifier": "com.github.evoke322.foliate4w",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "licenseFile": "../COPYING",
    "copyright": "Foliate contributors",
    "shortDescription": "Foliate e-book reader for Windows",
    "longDescription": "Foliate for Windows is a lightweight e-book reader built with Tauri 2 and WebView2, reusing the foliate-js reading engine.",
    "homepage": "https://github.com/vihaanvp/Foliate4w",
    "publisher": "Foliate contributors",
    "category": "Education",
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh",
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}
