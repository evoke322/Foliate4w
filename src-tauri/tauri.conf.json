{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Foliate for Windows",
  "version": "0.1.0",
  "identifier": "com.github.johnfactotum.foliate4w",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "category": "Reference",
    "copyright": "Copyright © Foliate contributors",
    "licenseFile": "../COPYING",
    "publisher": "Foliate contributors",
    "shortDescription": "Read EPUB, MOBI, FB2, CBZ and PDF books",
    "longDescription": "A lightweight Windows e-book reader powered by Foliate and WebView2.",
    "fileAssociations": [
      {
        "ext": ["epub"],
        "name": "Foliate EPUB",
        "description": "EPUB e-book",
        "role": "Viewer"
      },
      {
        "ext": ["mobi", "azw", "azw3"],
        "name": "Foliate Kindle",
        "description": "Mobipocket or Kindle e-book",
        "role": "Viewer"
      },
      {
        "ext": ["fb2", "fbz"],
        "name": "Foliate FictionBook",
        "description": "FictionBook e-book",
        "role": "Viewer"
      },
      {
        "ext": ["cbz"],
        "name": "Foliate Comic Book",
        "description": "Comic Book archive",
        "role": "Viewer"
      },
      {
        "ext": ["pdf"],
        "name": "Foliate PDF",
        "description": "PDF document",
        "role": "Viewer"
      }
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
