{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Foliate for Windows",
  "version": "0.1.0",
  "identifier": "com.github.evoke322.foliate4w",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "category": "Reference",
    "copyright": "Copyright © Foliate contributors",
    "licenseFile": "../COPYING",
    "publisher": "Foliate contributors",
    "shortDescription": "Read EPUB, MOBI, FB2, CBZ and PDF books",
    "longDescription": "A lightweight Windows e-book reader powered by Foliate and WebView2.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
